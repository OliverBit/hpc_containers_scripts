LOGIN_HOST=hpclogin.fht.org
ENGINE_DEFAULT=auto
ENGINE_MODULE=apptainer
HELPER_MODE=legacy
GROUP_ROOT=/group
GROUP_KALEBIC=/group/kalebic
GROUP_TESTA=/group/testa

# Keep large container cache off home.
CACHE_DIR=/group/kalebic/Oliviero/.apptainer-cache
ENGINE_TMP_DIR=/scratch/oliviero.leonardi/apptainer-tmp
CONTAINER_TMP_ROOT=/scratch/oliviero.leonardi/hpc-dev-tmp

STATE_ROOT=$HOME/.local/state/hpc-dev
DEV_HOME_ROOT=$HOME/.local/share/hpc-dev/home
DEFAULT_PARTITION=cpu-interactive
