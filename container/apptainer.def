Bootstrap: docker
From: ubuntu:24.04

%post
    export DEBIAN_FRONTEND=noninteractive
    export HPC_DEV_VENV=/opt/hpc-dev/venv
    export CODE_SERVER_VERSION=4.112.0
    export RSTUDIO_SERVER_VERSION=2026.01.1-403
    apt-get update
    apt-get install -y bash ca-certificates curl dropbear-bin gdebi-core git iproute2 less netcat-openbsd openssl openssh-server procps python3 python3-venv r-base
    curl -fsSLo /tmp/rstudio-server.deb "https://download2.rstudio.org/server/jammy/amd64/rstudio-server-${RSTUDIO_SERVER_VERSION}-amd64.deb"
    gdebi -n /tmp/rstudio-server.deb
    rm -f /tmp/rstudio-server.deb
    python3 -m venv "${HPC_DEV_VENV}"
    "${HPC_DEV_VENV}/bin/pip" install --no-cache-dir --upgrade pip
    "${HPC_DEV_VENV}/bin/pip" install --no-cache-dir jupyterlab
    curl -fsSL "https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VERSION}/code-server-${CODE_SERVER_VERSION}-linux-amd64.tar.gz" | tar -xz -C /usr/local/lib
    mv "/usr/local/lib/code-server-${CODE_SERVER_VERSION}-linux-amd64" /usr/local/lib/code-server
    ln -sf /usr/local/lib/code-server/bin/code-server /usr/local/bin/code-server
    mkdir -p /var/run/sshd

    install -d /usr/local/bin
    install -m 0755 /tmp/hpc-service-lib.sh /usr/local/bin/hpc-service-lib.sh
    install -m 0755 /tmp/hpc-service-sshd.sh /usr/local/bin/hpc-service-sshd.sh
    install -m 0755 /tmp/hpc-service-jupyter.sh /usr/local/bin/hpc-service-jupyter.sh
    install -m 0755 /tmp/hpc-service-rstudio.sh /usr/local/bin/hpc-service-rstudio.sh
    install -m 0755 /tmp/hpc-service-codeserver.sh /usr/local/bin/hpc-service-codeserver.sh

%files
    container/helpers/hpc-service-lib.sh /tmp/hpc-service-lib.sh
    container/helpers/hpc-service-sshd.sh /tmp/hpc-service-sshd.sh
    container/helpers/hpc-service-jupyter.sh /tmp/hpc-service-jupyter.sh
    container/helpers/hpc-service-rstudio.sh /tmp/hpc-service-rstudio.sh
    container/helpers/hpc-service-codeserver.sh /tmp/hpc-service-codeserver.sh

%runscript
    exec "$@"

%environment
    export HPC_DEV_VENV=/opt/hpc-dev/venv
    export PATH="${HPC_DEV_VENV}/bin:${PATH}"

%help
    Owned Apptainer definition for the hpc-dev workflow baseline.
    Includes explicit sshd, RStudio, Jupyter, and code-server helpers.
    Extend this with any site-specific certificates, mirrors, or extra tools before production use.
